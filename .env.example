# ==========================================
# Exemplo de configuração de variáveis de ambiente
# ==========================================
# IMPORTANTE: Se você estiver usando o Docker Compose para subir toda a plataforma
# (`docker compose up`), você NÃO precisa criar nem configurar arquivos .env.
# O arquivo compose.yaml já injeta automaticamente os valores corretos.
#
# Você só precisa criar os arquivos .env dentro das pastas dos serviços se for
# executá-los localmente na sua máquina (ex: via IDE, mvnw, ou uvicorn).
# Nesses casos, os hosts devem apontar para 'localhost' (se a infraestrutura 
# base já estiver rodando via Docker na sua máquina).
# ==========================================

# ------------------------------------------
# agent-service/.env
# ------------------------------------------
# SPRING_RABBITMQ_HOST=localhost
# SPRING_DATA_REDIS_HOST=localhost
# LLM_GATEWAY_URL=http://localhost:8767
# EUREKA_CLIENT_REGISTER_WITH_EUREKA=false
# EUREKA_CLIENT_FETCH_REGISTRY=false

# ------------------------------------------
# llm-gateway/.env
# ------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# LLM_MODEL=qwen2.5:0.5b

# ------------------------------------------
# retrieval-service/.env
# ------------------------------------------
# QDRANT_HOST=localhost
# QDRANT_PORT=6334
# OLLAMA_BASE_URL=http://localhost:11434
# EMBEDDING_MODEL=nomic-embed-text
# EUREKA_CLIENT_REGISTER_WITH_EUREKA=false
# EUREKA_CLIENT_FETCH_REGISTRY=false

# ------------------------------------------
# service-memory/.env
# ------------------------------------------
# DATABASE_URL=postgresql+asyncpg://root:root@localhost:5432/postgres
# REDIS_URL=redis://localhost:6379/0
